<view class="container">
  <!-- 用户信息 -->
  <view class="user-info">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"></image>
    <view class="user-details">
      <text class="nickname">{{userInfo.nickName || '未登录'}}</text>
      <text class="openid">{{openid}}</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="exportData">
      <text class="menu-icon">📤</text>
      <text class="menu-text">导出数据</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="importData">
      <text class="menu-icon">📥</text>
      <text class="menu-text">导入数据</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="clearData">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清空数据</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="settings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>记账本 v1.0.0</text>
  </view>
</view>