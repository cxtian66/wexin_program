/* stats.wxss */
.time-selector {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  margin: 20rpx 0;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.time-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #666;
}

.time-item.active {
  background-color: #07c160;
  color: #fff;
}

.overview-card {
  margin-bottom: 20rpx;
}

.overview-header {
  margin-bottom: 20rpx;
}

.overview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.overview-content {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 0;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.overview-amount {
  font-size: 36rpx;
  font-weight: bold;
}

.overview-amount.income {
  color: #07c160;
}

.overview-amount.expense {
  color: #ff4d4f;
}

.overview-divider {
  width: 1rpx;
  height: 80rpx;
  background-color: #f0f0f0;
}

.card {
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.type-toggle {
  display: flex;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 4rpx;
}

.toggle-item {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 16rpx;
}

.toggle-item.active {
  background-color: #07c160;
  color: #fff;
}

.chart-container {
  margin: 20rpx 0;
}

.category-list {
  margin-top: 20rpx;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item:last-child {
  border-bottom: none;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-amount {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.category-percent {
  font-size: 28rpx;
  color: #999;
}