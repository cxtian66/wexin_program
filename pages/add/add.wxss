/* add.wxss */
.type-selector {
  display: flex;
  margin: 30rpx 0;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #666;
}

.type-item.active {
  background-color: #07c160;
  color: #fff;
}

.amount-input {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.amount-symbol {
  font-size: 48rpx;
  color: #333;
  margin-right: 20rpx;
}

.amount-field {
  flex: 1;
  font-size: 64rpx;
  font-weight: bold;
  color: #333;
  border: none;
  outline: none;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 10rpx;
  font-size: 40rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.category-item.active {
  color: #07c160;
}

.category-item.active .category-name {
  color: #07c160;
}

.date-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
}

.remark-input {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 32rpx;
  resize: none;
}

.btn {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}