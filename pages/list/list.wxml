<view class="container">
  <!-- 筛选器 -->
  <view class="filter-bar">
    <view class="filter-item" bindtap="openDateFilter">
      <text class="filter-text">{{selectedDateRange}}</text>
      <text class="filter-icon">▼</text>
    </view>
    <view class="filter-item" bindtap="openCategoryFilter">
      <text class="filter-text">{{selectedCategory || '全部分类'}}</text>
      <text class="filter-icon">▼</text>
    </view>
  </view>

  <!-- 记账记录列表 -->
  <view class="record-list">
    <view wx:for="{{records}}" wx:key="_id" class="record-item" bindtap="goToEdit">
      <view class="record-left">
        <text class="record-category">{{item.categoryName}}</text>
        <text class="record-date">{{formatDate(item.date)}} {{item.time}}</text>
        <text class="record-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
      </view>
      <text class="record-amount {{item.type === 1 ? 'income' : 'expense'}}">
        {{item.type === 1 ? '+' : '-'}}¥{{item.amount}}
      </text>
    </view>
    <view wx:if="{{records.length === 0}}" class="empty-record">
      <text>暂无记账记录</text>
    </view>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">
    <text>加载更多</text>
  </view>
  <view wx:else class="no-more">
    <text>没有更多记录了</text>
  </view>
</view>